{
  "name": "ks0555-steam-deck-controller",
  "version": "0.0.1",
  "private": true,
  "description": "Steam Deck Bluetooth robot controller — Tauri v2 desktop app (Rust BLE via btleplug, gamepad via gilrs)",
  "scripts": {
    "dev": "pnpm --filter @ks0555/frontend tauri:dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "install:steamdeck": "./upgrade-robot-controller.sh",
    "prepare": "lefthook install"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/json": "^1.2.0",
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "catalog:",
    "lefthook": "^2.1.6",
    "prettier": "catalog:",
    "turbo": "^2.9.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "lefthook", "@tauri-apps/cli"]
  }
}
